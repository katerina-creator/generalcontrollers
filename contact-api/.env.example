# Contact API environment variables

# Server port (automatically set by Railway, default 3000)
PORT=3000

# Allowed origins (comma-separated)
# Must match your deployed site URL(s)
ALLOWED_ORIGINS=https://generalcontrollers-production.up.railway.app,http://localhost:3000

# SMTP Configuration
# Use your email provider's SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email destination and sender
# MAIL_TO is where contact form submissions are sent
MAIL_TO=nextgen.coders.lab@gmail.com
# MAIL_FROM is the sender address (typically same as SMTP_USER for authenticated sends)
MAIL_FROM=your-email@gmail.com
